def agregar_arreglo(codigo, nombre, tipo, color, tamaño, disponibilidad, temporada, precio, unidades, dicc_arreglos, dicc_bodega):

  if buscar_codigo(codigo, dicc_arreglos):

    return False

  cod_clave = codigo.upper()

  dicc_arreglos[cod_clave] = [nombre, tipo, color, tamaño.upper(), disponibilidad.lower(), temporada]

  dicc_bodega[cod_clave] = [int(precio), int(unidades)]

  return True

def eliminar_arreglo(codigo, dicc_arreglos, dicc_bodega):

  if not buscar_codigo(codigo, dicc_bodega):

    return False

  clave_arreglo = ""

  for clave in dicc_arreglos:

    if clave.upper() == codigo.upper():

      clave_arreglo = clave

      break

  del dicc_arreglos[clave_arreglo]

  del dicc_bodega[clave_arreglo]

  return True





