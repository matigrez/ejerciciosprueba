def validar_no_vacio(texto):

  return texto.strip() != ""

def validar_codigo(codigo, dicc_arreglos):

  if not codigo.strip():

    return False

  codigos_mayusculas = [clave.upper() for clave in dicc_arreglos()]

  return codigo.upper() not in codigos_mayusculas

def validar_tamaño(tamaño):

  return tamaño.upper() in ['S', 'M', 'L']

def validar_incluye_tarjetas(opcion): 

  return opcion.lower() in ['s', 'n']

def validar_precio(precio):

  try:

    return float(precio) > 0

  except ValueError:

    return False  

def validar_unidades(cantidad):

  try:

    return int(cantidad) >= 0

  except ValueError:

    return False



